<redisConfiguration namespacePrefix="opensai" />

<simvizConfiguration
	worldFilePath="${WORLD_FILES_FOLDER}/world_single_rizon.urdf">

	<simParameters frictionCoefficient="0.5" />

	<logger logFolderName="log_files/single_panda/simviz"
		enabledAtStartup="true"
		addTimestampToFilename="false" />

	<forceSensor robotOrObjectName="Rizon4R"
		linkName="flange"
		filterCutoff="5.0" />
</simvizConfiguration>


<robotControlConfiguration robotName="Rizon4r"
	robotModelFile="${ROBOT_FILES_FOLDER}/Rizon4r.urdf">

	<logger logFolderName="log_files/single_flexiv_real/controllers"
		enabledAtStartup="true"
		addTimestampToFilename="false" />

	<controller name="cartesian_controller">
		<motionForceTask name="cartesian_task"
			linkName="flange">
			<velocitySaturation enabled="true" />
			<otg type="disabled" />
			<!-- <positionGains>
				<kp value="400.0" />
				<kv value="40.0" />
			</positionGains> -->
		</motionForceTask>

		<jointTask name="joint_task">
			<otg type="disabled" />
			<gains>
				<kp value="400.0" />
				<kv value="40.0" />
			</gains>
		</jointTask>
	</controller>

	<controller name="joint_controller">
		<jointTask name="joint_task">
			<velocitySaturation enabled="true" />
			<otg type="disabled" />
		</jointTask>
	</controller>

</robotControlConfiguration>