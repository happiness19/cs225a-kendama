<?xml version="1.0" ?>

<world name="demo_world" gravity="0.0 0.0 -9.81">

	<robot name="Rizon4r">
		<model dir="${ROBOT_FILES_FOLDER}" path="Rizon4r_with_kendama.urdf" name="Rizon4r" />
	</robot>

	<static_object name="Floor">
		<origin xyz="0.0 0.0 -0.05" rpy="0 0 0" />
		<visual>
			<origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
			<geometry>
				<box size="5.0 5.0 0.1" />
			</geometry>
			<material name="material_blue">
				<color rgba="0.0 0.1 0.5 1.0" />
			</material>
		</visual>
		<collision>
			<origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
			<geometry>
				<box size="5.0 5.0 0.1" />
			</geometry>
		</collision>
	</static_object>

		<dynamic_object name="KendamaBall">
			<!-- Positioned on the big cup for the launch-time robot pose. -->
			<origin xyz="0.384426 0.074928 1.325000" rpy="0 0 0" />
			<inertial>
				<origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
				<mass value="0.075" />
				<inertia ixx="0.000027" iyy="0.000027" izz="0.000027" ixy="0" ixz="0" iyz="0" />
			</inertial>
			<visual>
				<origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
				<geometry>
					<sphere radius="0.03" />
				</geometry>
				<material name="kendama_ball_green">
					<color rgba="0.0 0.65 0.16 1.0" />
				</material>
			</visual>
			<collision>
				<origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
				<geometry>
					<sphere radius="0.03" />
				</geometry>
			</collision>
		</dynamic_object>

		<light name="light1" type="directional">
		<position xyz="2.0 -2.0 2.0" />
		<lookat xyz="0.0 0.0 0.5" />
	</light>

	<light name="light2" type="directional">
		<position xyz="2.0 2.0 2.0" />
		<lookat xyz="0.0 0.0 0.5" />
	</light>

	<camera name="camera_fixed">
		<position xyz="2.0 0.0 1.0" />
		<vertical xyz="0.0 0.0 1.0" />
		<lookat xyz="0.0 0.0 0.5" />
	</camera>

</world>
